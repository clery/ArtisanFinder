package-as: ArtisanFinder
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

externals:
  Libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk
  Libs/CallbackHandler-1.0: https://repos.curseforge.com/wow/callbackhandler/trunk/CallbackHandler-1.0
  Libs/LibDataBroker-1.1: https://repos.curseforge.com/wow/libdatabroker-1-1
  Libs/LibDBIcon-1.0: https://repos.curseforge.com/wow/libdbicon-1-0/trunk/LibDBIcon-1.0
  Libs/ChatThrottleLib: https://repos.curseforge.com/wow/chatthrottlelib/trunk
  Libs/LibEditMode: https://github.com/p3lim-wow/LibEditMode.git

ignore:
  - .githooks
  - README.md
  - Images/CrafterView.png
  - Images/CustomerView.png
  - Images/CustomerViewPopup.png
  - Images/Example.gif
  - Images/Options1.png
  - Images/Options2.png
